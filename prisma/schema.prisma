generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAYMENT_CONFIRMED
  PREPARING
  ALMOST_READY
  READY_FOR_PICKUP
  COMPLETED
  CANCELED
}

enum PaymentStatus {
  UNPAID
  PAID
  CANCELED
}

model Restaurant {
  id               String            @id @default(cuid())
  slug             String            @unique
  name             String
  description      String
  address          String
  currency         String            @default("NZD")
  isOpen           Boolean           @default(true)
  isServiceActive  Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  categories       Category[]
  menuItems        MenuItem[]
  orders           Order[]
  staffCredentials StaffCredential[]
}

model StaffCredential {
  id           String     @id @default(cuid())
  restaurantId String
  role         String
  label        String?
  pinHash      String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, role])
  @@index([restaurantId])
}

model Category {
  id           String     @id @default(cuid())
  restaurantId String
  name         String
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  menuItems    MenuItem[]

  @@index([restaurantId, sortOrder])
}

model MenuItem {
  id               String      @id @default(cuid())
  restaurantId     String
  categoryId       String
  name             String
  description      String
  priceCents       Int
  imageUrl         String?
  optionGroupsJson String      @default("[]")
  isSoldOut        Boolean     @default(false)
  isActive         Boolean     @default(true)
  sortOrder        Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  restaurant       Restaurant  @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  category         Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems       OrderItem[]

  @@index([restaurantId, categoryId, sortOrder])
}

model Order {
  id                  String             @id @default(cuid())
  restaurantId        String
  orderNumber         Int
  orderCode           String             @unique
  submissionKey       String             @unique
  customerAccessToken String?            @unique
  customerName        String?
  customerNote        String?
  status              OrderStatus        @default(AWAITING_PAYMENT)
  paymentStatus       PaymentStatus      @default(UNPAID)
  totalCents          Int
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  paidAt              DateTime?
  canceledAt          DateTime?
  completedAt         DateTime?
  restaurant          Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  items               OrderItem[]
  statusEvents        OrderStatusEvent[]

  @@unique([restaurantId, orderNumber])
  @@index([restaurantId, orderNumber])
  @@index([restaurantId, status, paymentStatus, createdAt])
}

model OrderItem {
  id                  String    @id @default(cuid())
  orderId             String
  menuItemId          String?
  name                String
  unitPriceCents      Int
  quantity            Int
  note                String?
  selectedOptionsJson String    @default("[]")
  lineTotalCents      Int
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem            MenuItem? @relation(fields: [menuItemId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
}
