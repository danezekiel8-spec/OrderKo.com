{
  "name": "orderko",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start.js",
    "start:next": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "env:check": "node scripts/check-env.js",
    "env:check:production": "node scripts/check-env.js --production",
    "db:generate": "prisma generate",
    "db:generate:postgres": "prisma generate --schema prisma/postgres/schema.prisma",
    "db:migrate": "node scripts/setup-db.js --no-seed",
    "db:deploy:postgres": "prisma migrate deploy --schema prisma/postgres/schema.prisma",
    "db:bootstrap:g-cafe": "node scripts/bootstrap-g-cafe.js",
    "build:render": "npm run env:check:production && npm run db:generate:postgres && npm run build",
    "start:render": "npm run db:generate:postgres && npm run db:deploy:postgres && npm run start:next",
    "db:reset": "ORDERKO_ALLOW_DB_RESET=local-dev-only node scripts/setup-db.js --reset",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio",
    "test:smoke": "node scripts/smoke-test.js",
    "test:prod-smoke": "node scripts/prod-smoke.js"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "prisma": "^6.19.3",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
